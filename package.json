{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "next dev -p 9002",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true}); try{require('node:fs').rmSync('node_modules/.cache',{recursive:true,force:true})}catch(e){}\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "deploy": "cross-env FUNCTIONS_DISCOVERY_TIMEOUT=180 firebase deploy",
    "deploy:clean": "npm run clean && cross-env FUNCTIONS_DISCOVERY_TIMEOUT=180 firebase deploy",
    "deploy:hosting": "cross-env FUNCTIONS_DISCOVERY_TIMEOUT=180 firebase deploy --only hosting",
    "deploy:full": "npm run fix:gcp && npm run deploy",
    "fix:gcp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-gcp-iam.ps1",
    "fix:gcp:sh": "bash scripts/fix-gcp-iam.sh",
    "fix:invoker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-ssr-public-invoker.ps1",
    "fix:invoker:sh": "bash scripts/fix-ssr-public-invoker.sh",
    "remove:member": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/remove-gcp-project-member.ps1",
    "copy:firestore-employees": "node scripts/copy-firestore-employees.mjs",
    "migrate:shared-seed": "npx tsx scripts/migrate-seed-shared-schema.ts",
    "migrate:shared-db": "npx tsx scripts/migrate-shared-db.ts",
    "validate:shared-db": "npx tsx scripts/validate-shared-db.ts",
    "test:shared-mappers": "node --import tsx --test src/lib/shared-data/mappers.node-test.ts src/lib/shared-data/merge-utils.node-test.ts",
    "test:handoff": "node --import tsx --test src/lib/handoff/planport-ledger/v1.node-test.ts src/lib/handoff/planport-ledger/v2.node-test.ts",
    "migrate:external-ids": "npx tsx scripts/ledger-backfill-external-ids.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@genkit-ai/google-genai": "^1.31.0",
    "@google/genai": "^1.46.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@vis.gl/react-google-maps": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^7.2.2",
    "genkit": "^1.31.0",
    "html-to-text": "^9.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.475.0",
    "luxon": "^3.7.2",
    "mapbox-gl": "^3.9.4",
    "next": "^15.5.14",
    "patch-package": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-to-img": "^4.5.0",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.3",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.54.2",
    "react-map-gl": "^7.1.7",
    "recharts": "^2.15.1",
    "resend": "^3.5.0",
